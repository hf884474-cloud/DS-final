public class Searcher {
    /**
     * Performs linear search on an array.
     * @return the index of the element if found, otherwise -1.
     */
    public int findIndex(int[] arr, int size, int target) {
        for (int i = 0; i < size; i++) {
            if (arr[i] == target) {
                return i; // Target found
            }
        }
        return -1; // Target not found
    }
}
import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Searcher searcher = new Searcher(); // Create an instance of our logic class
        
        int[] numbers = new int[10];
        
        System.out.print("Enter number of elements (1-10): ");
        int n = scanner.nextInt();

        if (n > 10 || n < 1) {
            System.out.println("Error: Size must be between 1 and 10.");
            return;
        }

        System.out.println("Enter " + n + " numbers:");
        for (int i = 0; i < n; i++) {
            numbers[i] = scanner.nextInt();
        }

        System.out.print("Enter search target: ");
        int target = scanner.nextInt();

        // Calling the method from the separate class
        int result = searcher.findIndex(numbers, n, target);

        if (result != -1) {
            System.out.println("Success! Element found at index " + result);
        } else {
            System.out.println("Element not found in the list.");
        }

        scanner.close();
    }
}
