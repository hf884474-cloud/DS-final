import java.util.Scanner;

public class LinearSearch {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        // 1. Initialize array with a maximum size of 10
        int[] numbers = new int[10];
        int n;

        System.out.print("Enter the number of elements (max 10): ");
        n = scanner.nextInt();

        // Safety check for array bounds
        if (n > 10 || n < 1) {
            System.out.println("Invalid size! Please enter a number between 1 and 10.");
            return;
        }

        // 2. Input elements into the array
        System.out.println("Enter " + n + " integers:");
        for (int i = 0; i < n; i++) {
            numbers[i] = scanner.nextInt();
        }

        // 3. Input the target element to find
        System.out.print("Enter the value to search for: ");
        int target = scanner.nextInt();

        // 4. Perform Linear Search
        int foundIndex = -1; 
        for (int i = 0; i < n; i++) {
            if (numbers[i] == target) {
                foundIndex = i; // Store the index if found
                break;          // Exit loop early once found
            }
        }

        // 5. Output results
        if (foundIndex != -1) {
            System.out.println("Element " + target + " found at index: " + foundIndex);
        } else {
            System.out.println("Element " + target + " not found in the list.");
        }

        scanner.close();
    }
}
