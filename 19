import java.util.Scanner;

class BinarySearcher {
    
    // 1. Manual Bubble Sort Logic (Replaces Arrays.sort)
    public void sort(int[] arr, int n) {
        for (int i = 0; i < n - 1; i++) {
            for (int j = 0; j < n - i - 1; j++) {
                if (arr[j] > arr[j + 1]) {
                    // Swap elements using a temporary variable
                    int temp = arr[j];
                    arr[j] = arr[j + 1];
                    arr[j + 1] = temp;
                }
            }
        }
    }
    
    // 2. Manual Binary Search Logic (Replaces Arrays.binarySearch)
    public int search(int[] arr, int n, int target) {
        int low = 0;
        int high = n - 1;

        while (low <= high) {
            int mid = low + (high - low) / 2;

            if (arr[mid] == target) {
                return mid; // Found it!
            }
            if (arr[mid] < target) {
                low = mid + 1; // Look in the right half
            } else {
                high = mid - 1; // Look in the left half
            }
        }
        return -1; // Not found
    }
}

public class BinaryMain {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        BinarySearcher bSearch = new BinarySearcher();
        
        int[] numbers = new int[10];
        
        System.out.print("Enter number of elements (max 10): ");
        int n = sc.nextInt();

        if (n > 10 || n < 1) {
            System.out.println("Invalid size.");
            return;
        }

        System.out.println("Enter " + n + " numbers:");
        for (int i = 0; i < n; i++) {
            numbers[i] = sc.nextInt();
        }

        // Sort the array manually
        bSearch.sort(numbers, n);

        // Print the array manually (Simplified loop)
        System.out.print("Sorted array: [");
        for (int i = 0; i < n; i++) {
            System.out.print(numbers[i]);
            if (i < n - 1) {
                System.out.print(", ");
            }
        }
        System.out.println("]");

        System.out.print("Enter value to find: ");
        int target = sc.nextInt();

        // Search the array manually
        int result = bSearch.search(numbers, n, target);

        if (result != -1) {
            System.out.println("Element found at index " + result);
        } else {
            System.out.println("Element not found.");
        }
        
        sc.close();
    }
}
